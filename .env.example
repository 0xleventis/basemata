# Copy this to .env for local development
# In Railway: set these under your service → Variables tab

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Your Railway app URL (set after first deploy)
# e.g. https://token-registry-production.up.railway.app
APP_URL=https://your-app.up.railway.app

# Optional: restrict CORS to your domain
# Leave blank to allow all origins during development
ALLOWED_ORIGIN=https://your-app.up.railway.app
